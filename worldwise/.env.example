# Human login password — used ONLY for first-run owner bootstrap.
ADMIN_PASSWORD=your_secure_password_here

# Signing key for session tokens. MUST be high-entropy and DIFFERENT from
# ADMIN_PASSWORD. Generate with: openssl rand -base64 48
# Changing it logs out all existing admin sessions.
SESSION_SECRET=generate_a_long_random_value_here

# Telegram notifications for new leads (recommended — instant)
# Create a bot via @BotFather, paste token here.
# TELEGRAM_CHAT_ID accepts a single ID or comma-separated list:
#   - For a group chat: add the bot to the group, then put the group's chat_id here
#     (group IDs are negative, e.g. -1001234567890)
#   - For individual DMs: each person /start the bot, then list IDs:
#     TELEGRAM_CHAT_ID=172397677,123456789,987654321
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_ID=@WorldwisePro

# Email notifications for new leads (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=info@worldwise.pro

# Public vars
NEXT_PUBLIC_WHATSAPP=971506960435
NEXT_PUBLIC_PHONE=+971506960435
NEXT_PUBLIC_EMAIL=info@worldwise.pro
NEXT_PUBLIC_SITE_URL=https://worldwise.pro
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). GA loads only after cookie
# consent; if unset, analytics is silently disabled.
NEXT_PUBLIC_GA_ID=

# Auto-publishing blog articles via Gemini + Telegram
GEMINI_API_KEY=
WEBHOOK_SECRET=

# Google Geocoding API key (server-side only, used by scripts/seed-coords.cjs to
# populate Property.lat/lng). Enable "Geocoding API" in GCP project worldwise-497520
# and create an API key. Stays in server .env.local (rsync-excluded), never shipped to the client.
GOOGLE_GEOCODING_API_KEY=

# Google Search Console CLI (scripts/gsc.mjs — local diagnostics + weekly Telegram digest cron).
# OAuth 2.0 Desktop client from GCP project worldwise-497520. GSC_REFRESH_TOKEN is written by
# `node --env-file=.env.local scripts/gsc.mjs auth`. GSC_SITE_URL defaults to https://worldwise.pro/.
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
GSC_SITE_URL=https://worldwise.pro/

# Weekly self-audit cron (scripts/seo-audit.mjs) — both optional, sane defaults.
# SEO_AUDIT_SITE overrides the audited origin; SEO_AUDIT_DRY_RUN=1 skips the Telegram post.
SEO_AUDIT_SITE=https://worldwise.pro
SEO_AUDIT_DRY_RUN=
