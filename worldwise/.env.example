# Human login password — used ONLY for first-run owner bootstrap.
ADMIN_PASSWORD=your_secure_password_here

# Signing key for session tokens. MUST be high-entropy and DIFFERENT from
# ADMIN_PASSWORD. Generate with: openssl rand -base64 48
# Changing it logs out all existing admin sessions.
SESSION_SECRET=generate_a_long_random_value_here

# Telegram notifications for new leads (recommended — instant)
# Create a bot via @BotFather, paste token here.
# TELEGRAM_CHAT_ID accepts a single ID or comma-separated list:
#   - For a group chat: add the bot to the group, then put the group's chat_id here
#     (group IDs are negative, e.g. -1001234567890)
#   - For individual DMs: each person /start the bot, then list IDs:
#     TELEGRAM_CHAT_ID=172397677,123456789,987654321
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_ID=@worldwisellc

# Russian social fan-out (lib/social-post.ts): approved plan posts are mirrored
# from the Telegram channel to VK and Odnoklassniki. Each network is optional —
# missing vars = network silently skipped. See docs/marketing/2026-07-04-russia-phase1-setup.md
# VK: needs TWO tokens because VK mirrors their permissions (2026-07-08):
#     VK_ACCESS_TOKEN — admin USER token (wall,photos scopes) — uploads photos;
#       VK denies it wall.* entirely when the app is deemed non-standalone ([15/1134]).
#     VK_WALL_TOKEN — COMMUNITY key (Управление → Настройки → Работа с API) — posts
#       the wall; can't upload photos ([27]). Unset = wall.post falls back to
#       VK_ACCESS_TOKEN (works only if VK still honours the app as standalone).
#     VK_GROUP_ID is the positive numeric id.
VK_ACCESS_TOKEN=
VK_WALL_TOKEN=
VK_GROUP_ID=
# OK: application key/secret from ok.ru/devaccess + permanent group access token
#     with VALUABLE_ACCESS;PHOTO_CONTENT;GROUP_CONTENT. OK_GROUP_ID is numeric.
#     For a permanent "вечный session_key" set OK_SESSION_SECRET to the issued
#     Session_secret_key (OK_APP_SECRET may then be omitted).
OK_ACCESS_TOKEN=
OK_APP_KEY=
OK_APP_SECRET=
OK_SESSION_SECRET=
OK_GROUP_ID=

# Email notifications for new leads (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=info@worldwise.pro

# Public vars
NEXT_PUBLIC_WHATSAPP=971506960435
NEXT_PUBLIC_PHONE=+971506960435
NEXT_PUBLIC_EMAIL=info@worldwise.pro
NEXT_PUBLIC_SITE_URL=https://worldwise.pro
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). GA loads only after cookie
# consent; if unset, analytics is silently disabled.
NEXT_PUBLIC_GA_ID=

# Auto-publishing blog articles via Gemini + Telegram
GEMINI_API_KEY=
WEBHOOK_SECRET=

# Google Geocoding API key (server-side only, used by scripts/seed-coords.cjs to
# populate Property.lat/lng). Enable "Geocoding API" in GCP project worldwise-497520
# and create an API key. Stays in server .env.local (rsync-excluded), never shipped to the client.
GOOGLE_GEOCODING_API_KEY=

# Google Search Console CLI (scripts/gsc.mjs — local diagnostics + weekly Telegram digest cron).
# OAuth 2.0 Desktop client from GCP project worldwise-497520. GSC_REFRESH_TOKEN is written by
# `node --env-file=.env.local scripts/gsc.mjs auth`. GSC_SITE_URL defaults to https://worldwise.pro/.
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
GSC_SITE_URL=https://worldwise.pro/

# Basic Auth for the Google Ads offline-conversion feed (GET /api/google-ads-oci),
# fetched weekly by the Ads scheduled import (Uploads → Schedules → HTTPS).
# Feed answers 401 until both are set. Generate: openssl rand -hex 16
OCI_FEED_USER=
OCI_FEED_PASS=

# Weekly self-audit cron (scripts/seo-audit.mjs) — both optional, sane defaults.
# SEO_AUDIT_SITE overrides the audited origin; SEO_AUDIT_DRY_RUN=1 skips the Telegram post.
SEO_AUDIT_SITE=https://worldwise.pro
SEO_AUDIT_DRY_RUN=

# Property Finder Enterprise API (leads → CRM webhook). Server-only.
PF_API_KEY=
PF_API_SECRET=
PF_WEBHOOK_SECRET=

# Property Finder listings (integration #2 — publish catalog → PF). Server-only.
# SEPARATE key from the leads one above, scoped listings:full_access + users:read
# (least-privilege, independently revocable; the leads key stays untouched).
# PF_COMPANY_LICENSE = DET trade licence (verify vs RERA ORN at pilot).
# PF_PUBLIC_PROFILE_ID = resolve once via GET /v1/users (owner's publicProfile.id).
PF_LISTINGS_API_KEY=
PF_LISTINGS_API_SECRET=
PF_COMPANY_LICENSE=
PF_PUBLIC_PROFILE_ID=

# DataForSEO API credentials (weekly keyword-discovery cron, scripts/discover-keywords.mjs)
# Get from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
