# Dependencies
**/node_modules/

# Next.js build output
**/.next/
**/out/

# Environment files (contain secrets like ADMIN_PASSWORD)
**/.env
**/.env.local
**/.env.*.local

# Server-only data store — ALL of data/ lives on the server, never committed.
# Holds customer PII (leads.json), bcrypt password hashes (users.json), the live
# catalog (properties.json), AI article state, and import staging. Back up via
# server snapshot, NOT git. (Previously only leads.json + property-drafts.json
# were ignored, leaving users.json/properties.json/articles.json committable.)
worldwise/data/

# Uploaded client documents — contain customer PII.
# Stored outside public/ (served only via authenticated route) — never commit.
worldwise/lead-files/
# Legacy location (pre-P3); kept ignored for safety.
worldwise/public/files/
# Server-generated per-article blog images (AI photo + branded card)
worldwise/public/images/blog/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Logs
*.log
npm-debug.log*

# RuVector tooling local DB (binary; not source)
ruvector.db

# Personal Claude Code hooks (machine-local workflow)
.claude/hooks/

# Playwright MCP scratch output (screenshots/snapshots/console logs)
.playwright-mcp/
